<% layout('layouts/boilerplate') %>

<section class="page-section">
    <div class="container-shell">
        <div class="detail-shell">
            <div class="content-panel">
                <a href="/listings" class="breadcrumbs"><i class="fa-solid fa-arrow-left"></i> Back to listings</a>

                <div class="detail-media">
                    <div class="detail-media-main">
                        <img src="<%= listing.image.url %>" alt="<%= listing.image.alt || listing.title %>">
                    </div>
                    <div class="detail-media-stack">
                        <div class="mini-shot">
                            <img src="<%= listing.image.url %>" alt="<%= listing.image.alt || listing.title %>">
                        </div>
                        <div class="mini-shot">
                            <img src="<%= listing.image.url %>" alt="<%= listing.image.alt || listing.title %>">
                        </div>
                        <div class="mini-shot">
                            <img src="<%= listing.image.url %>" alt="<%= listing.image.alt || listing.title %>">
                        </div>
                    </div>
                </div>

                <div class="detail-head">
                    <div>
                        <h1 class="detail-title"><%= listing.title %></h1>
                        <div class="detail-location"><i class="fa-solid fa-location-dot"></i> <%= listing.location %>, <%= listing.country %></div>
                        <% if (listing.owner) { %>
                        <div class="detail-location" style="margin-top:8px; font-size:0.98rem;">
                            <i class="fa-solid fa-user-pen"></i>
                            Hosted by <strong><%= listing.owner.username %></strong>
                            <% if (listing.owner.email) { %>
                            <span class="muted-copy">(<%= listing.owner.email %>)</span>
                            <% } %>
                        </div>
                        <% } %>
                    </div>
                    <div class="chip-row">
                        <span class="chip"><i class="fa-solid fa-star"></i> 4.7 guest rating</span>
                        <span class="chip"><i class="fa-solid fa-bolt"></i> Instant booking feel</span>
                    </div>
                </div>

                <p class="detail-blurb"><%= listing.description %></p>

                <div class="detail-tag-row">
                    <div class="tag-card">
                        <i class="fa-solid fa-house"></i>
                        <strong>Private stay</strong>
                        <span class="muted-copy">A focused, cozy setup for solo trips, couples, or calm group plans.</span>
                    </div>
                    <div class="tag-card">
                        <i class="fa-solid fa-wifi"></i>
                        <strong>Work-friendly</strong>
                        <span class="muted-copy">A comfortable home base for quick check-ins, planning, and longer stays.</span>
                    </div>
                    <div class="tag-card">
                        <i class="fa-solid fa-heart"></i>
                        <strong>Memorable atmosphere</strong>
                        <span class="muted-copy">Designed to feel warm, polished, and easy to choose at a glance.</span>
                    </div>
                </div>

                <h2 class="section-heading">What this stay offers</h2>
                <div class="offer-grid">
                    <div class="offer-card"><i class="fa-solid fa-bed"></i> Comfortable sleeping setup</div>
                    <div class="offer-card"><i class="fa-solid fa-utensils"></i> Space for meals and lounging</div>
                    <div class="offer-card"><i class="fa-solid fa-camera-retro"></i> Photo-worthy interiors</div>
                    <div class="offer-card"><i class="fa-solid fa-route"></i> Great launch point for exploring</div>
                </div>

                <h2 class="section-heading">Guest Reviews</h2>
                <p class="section-subtext">Clean feedback forms, clearer review cards, and a stronger content rhythm make this page feel much more complete.</p>

                <form action="/listings/<%= listing._id %>/reviews" method="POST" class="needs-validation review-form" novalidate>
                    <div class="field-group">
                        <label class="form-label-soft">Your rating</label>
                        <div class="star-rating">
                            <input type="radio" id="star5" name="rating" value="5" />
                            <label for="star5" title="5 stars"><i class="fa-solid fa-star"></i></label>
                            <input type="radio" id="star4" name="rating" value="4" />
                            <label for="star4" title="4 stars"><i class="fa-solid fa-star"></i></label>
                            <input type="radio" id="star3" name="rating" value="3" />
                            <label for="star3" title="3 stars"><i class="fa-solid fa-star"></i></label>
                            <input type="radio" id="star2" name="rating" value="2" />
                            <label for="star2" title="2 stars"><i class="fa-solid fa-star"></i></label>
                            <input type="radio" id="star1" name="rating" value="1" checked />
                            <label for="star1" title="1 star"><i class="fa-solid fa-star"></i></label>
                        </div>
                    </div>
                    <div class="field-group">
                        <label for="comment">Tell future guests what stood out</label>
                        <textarea id="comment" name="comment" class="form-control form-textarea" rows="4" required placeholder="Share details of your experience at this stay."></textarea>
                        <div class="invalid-feedback">Please add a short review before submitting.</div>
                    </div>
                    <button type="submit" class="btn-primary">Submit review</button>
                </form>

                <% if (listing.reviews.length > 0) { %>
                <div class="review-grid">
                    <% for (let review of listing.reviews) { %>
                    <div class="review-card">
                        <h5>
                            <%= review.author ? review.author.username : 'Anonymous' %>
                        </h5>
                        <h5>Rating: <%= review.rating %> <i class="fa-solid fa-star" style="color:#f2a84a;"></i></h5>
                        <p><%= review.comment %></p>
                        <% if (currentUser && review.author && review.author.clerkId === currentUser.clerkId) { %>
                        <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                            <button class="btn-danger" type="submit">Delete review</button>
                        </form>
                        <% } %>
                    </div>
                    <% } %>
                </div>
                <% } %>

                <!-- Map Section -->
                <h2 class="section-heading" style="margin-top: 40px;">Where you'll be</h2>
                <p class="section-subtext">Exact location details will be shared after booking confirmation.</p>
                <div id="map" style="height: 380px; width: 100%; border-radius: var(--radius-lg); border: 1px solid var(--border-soft); box-shadow: var(--shadow-soft); margin-bottom: 40px;"></div>
            </div>

            <!-- Include Leaflet.js assets and initialisation -->
            <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
            <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
            <script>
                document.addEventListener("DOMContentLoaded", async () => {
                    const listingTitle = "<%= listing.title %>";
                    const listingLocation = "<%= listing.location %>";
                    const listingCountry = "<%= listing.country %>";

                    let coordinates = JSON.parse('<%- JSON.stringify(listing.geometry && listing.geometry.coordinates && listing.geometry.coordinates.length > 0 ? listing.geometry.coordinates : null) %>');

                    // If coordinates are missing or default, attempt to geocode using the specific listing location
                    if (!coordinates || (coordinates[0] === 77.2090 && coordinates[1] === 28.6139)) {
                        try {
                            const query = `${listingLocation}, ${listingCountry}`;
                            const response = await fetch(`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(query)}&format=json&limit=1`);
                            if (response.ok) {
                                const data = await response.json();
                                if (data && data.length > 0) {
                                    coordinates = [parseFloat(data[0].lon), parseFloat(data[0].lat)];
                                }
                            }
                        } catch (err) {
                            console.error("Client-side geocoding failed:", err);
                        }
                    }

                    // Fallback to Delhi coordinates if both db and dynamic geocoding fail
                    if (!coordinates) {
                        coordinates = [77.2090, 28.6139];
                    }

                    // Note: Leaflet expects [latitude, longitude] while GeoJSON uses [longitude, latitude]
                    const latLng = [coordinates[1], coordinates[0]];

                    const map = L.map('map').setView(latLng, 13);

                    // Use OpenStreetMap tile layer
                    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                        maxZoom: 19,
                        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
                    }).addTo(map);

                    // Create a custom styled HTML pin matching the theme
                    const customPin = L.divIcon({
                        className: 'custom-map-pin',
                        html: `<div style="
                            background-color: #2f6a56; 
                            width: 36px; 
                            height: 36px; 
                            border-radius: 50% 50% 50% 0; 
                            transform: rotate(-45deg); 
                            display: flex; 
                            align-items: center; 
                            justify-content: center; 
                            border: 2px solid #fff; 
                            box-shadow: 0 4px 10px rgba(24, 50, 42, 0.25);
                        "><i class="fa-solid fa-house" style="color: #fff; transform: rotate(45deg); font-size: 0.9rem;"></i></div>`,
                        iconSize: [36, 36],
                        iconAnchor: [18, 36],
                        popupAnchor: [0, -36]
                    });

                    // Add marker with popup
                    L.marker(latLng, { icon: customPin }).addTo(map)
                        .bindPopup(`<div style="font-family: 'Manrope', sans-serif; padding: 4px; min-width: 140px;">
                            <strong style="color: #18322a; font-size: 0.95rem; display: block; margin-bottom: 2px;">${listingTitle}</strong>
                            <span style="color: #434f45; font-size: 0.8rem; display: block;"><i class="fa-solid fa-location-dot" style="margin-right: 4px;"></i>${listingLocation}</span>
                        </div>`)
                        .openPopup();
                });
            </script>

            <aside class="booking-panel" id="bookingPanel">
                <!-- Main Form Wrapper -->
                <div id="bookingFormWrapper">
                    <div class="booking-panel-top">
                        <div>
                            <div class="booking-price">&#8377;<span id="basePriceDisplay"><%= listing.price.toLocaleString("en-IN") %></span> <span>/ night</span></div>
                            <div class="booking-meta"><i class="fa-solid fa-star"></i> 4.7 average rating</div>
                        </div>
                        <span class="chip">Popular pick</span>
                    </div>

                    <div class="booking-form-card" id="bookingFormCard">
                        <div class="booking-row">
                            <div class="booking-field" id="checkinField">
                                <label for="checkin">Check in</label>
                                <input id="checkin" type="text" placeholder="Add date" onfocus="this.type='date'" onblur="if(!this.value)this.type='text'">
                            </div>
                            <div class="booking-field" id="checkoutField">
                                <label for="checkout">Check out</label>
                                <input id="checkout" type="text" placeholder="Add date" onfocus="this.type='date'" onblur="if(!this.value)this.type='text'">
                            </div>
                        </div>
                        <div class="booking-field-full">
                            <label for="guests">Guests</label>
                            <select id="guests">
                                <option value="1">1 guest</option>
                                <option value="2">2 guests</option>
                                <option value="3">3 guests</option>
                                <option value="4">4 guests</option>
                                <option value="5">5+ guests</option>
                            </select>
                        </div>
                    </div>

                    <div id="bookingErrorAlert" style="display: none; background-color: #fce8e6; border: 1px solid #f8b4b4; color: #a82020; padding: 10px 14px; border-radius: 12px; font-size: 0.85rem; font-weight: 600; margin-bottom: 14px; align-items: center; gap: 8px;">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        <span id="bookingErrorText">Please select check-in and check-out dates.</span>
                    </div>

                    <button class="btn-primary" type="button" style="width:100%;" id="reserveBtn">Reserve now</button>
                    <p class="section-subtext" style="margin:12px 0 0;">Nothing is charged yet. This panel is here to make the stay feel bookable and complete.</p>

                    <div class="price-breakdown" id="priceBreakdown">
                        <div class="price-line"><span id="nightsLabel">&#8377;<%= listing.price.toLocaleString("en-IN") %> x 2 nights</span><span id="rawTotalDisplay">&#8377;<%= (listing.price * 2).toLocaleString("en-IN") %></span></div>
                        <div class="price-line"><span>Service fee</span><span id="serviceFeeDisplay">&#8377;<%= Math.round(listing.price * 0.12).toLocaleString("en-IN") %></span></div>
                        <div class="price-total"><span>Total before taxes</span><span id="grandTotalDisplay">&#8377;<%= Math.round((listing.price * 2) + (listing.price * 0.12)).toLocaleString("en-IN") %></span></div>
                    </div>

                    <div class="quick-facts">
                        <div class="fact-card">
                            <i class="fa-solid fa-broom"></i>
                            <strong>Clean presentation</strong>
                            <span class="muted-copy">The UI now highlights quality and trust faster.</span>
                        </div>
                        <div class="fact-card">
                            <i class="fa-solid fa-pen-ruler"></i>
                            <strong>Sharper hierarchy</strong>
                            <span class="muted-copy">Pricing, place details, and reviews are easier to scan.</span>
                        </div>
                    </div>
                </div>

                <!-- Loading State Wrapper -->
                <div id="bookingLoadingWrapper" style="display: none; text-align: center; padding: 40px 10px;">
                    <div class="booking-spinner"></div>
                    <h3 style="font-weight: 800; color: var(--brand-ink); margin-bottom: 20px;">Securing your request</h3>
                    <div style="display: inline-block; text-align: left; margin: 0 auto;">
                        <div class="step-item" id="step1"><i class="fa-solid fa-hourglass-half"></i> Verifying dates...</div>
                        <div class="step-item" id="step2"><i class="fa-solid fa-lock"></i> Securing best price rate...</div>
                        <div class="step-item" id="step3"><i class="fa-solid fa-ticket"></i> Generating reservation token...</div>
                    </div>
                </div>

                <!-- Success Confirmation Wrapper -->
                <div id="bookingSuccessWrapper" style="display: none; text-align: center; position: relative;">
                    <div class="confetti-container" id="confettiContainer"></div>
                    <div class="success-checkmark">
                        <div class="check-icon">
                            <div class="check-icon-circle"></div>
                            <div class="check-icon-fix"></div>
                            <div class="check-line check-line-tip"></div>
                            <div class="check-line check-line-long"></div>
                        </div>
                    </div>
                    <h3 style="font-weight: 800; color: var(--brand-moss); margin-top: 15px; margin-bottom: 6px;">Stay Reserved!</h3>
                    <p class="section-subtext" style="margin-bottom: 24px;">Your mock booking has been secured successfully.</p>
                    
                    <div style="background: var(--surface-tint); border: 1px solid var(--border-soft); border-radius: var(--radius-md); padding: 18px; text-align: left; margin-bottom: 24px;">
                        <div style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--border-soft); padding-bottom: 10px; margin-bottom: 10px;">
                            <span style="font-size: 0.75rem; text-transform: uppercase; font-weight: 800; color: var(--text-soft);">Booking Status</span>
                            <span style="font-size: 0.75rem; text-transform: uppercase; font-weight: 800; color: #4CAF50;"><i class="fa-solid fa-circle-check"></i> Confirmed</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 0.9rem;">
                            <span style="color: var(--text-soft);">Booking ID:</span>
                            <strong style="color: var(--brand-ink);" id="successBookingId">RM-2384-90E</strong>
                        </div>
                        <div style="display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 0.9rem;">
                            <span style="color: var(--text-soft);">Dates Selected:</span>
                            <strong style="color: var(--brand-ink);" id="successDates">Jul 22 - Jul 24</strong>
                        </div>
                        <div style="display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 0.9rem;">
                            <span style="color: var(--text-soft);">Total Stay:</span>
                            <strong style="color: var(--brand-ink);" id="successNights">2 nights</strong>
                        </div>
                        <div style="display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 0.9rem;">
                            <span style="color: var(--text-soft);">Guests:</span>
                            <strong style="color: var(--brand-ink);" id="successGuests">2 guests</strong>
                        </div>
                        <div style="display: flex; justify-content: space-between; border-top: 1px dashed var(--border-soft); padding-top: 10px; margin-top: 10px;">
                            <strong style="color: var(--brand-ink);">Total Mock Paid</strong>
                            <strong style="color: var(--brand-moss); font-size: 1.1rem;" id="successTotal">&#8377;12,400</strong>
                        </div>
                    </div>

                    <button class="btn-secondary" type="button" style="width:100%;" id="resetBookingBtn">Cancel / Reset Mock Stay</button>
                </div>

                <% if (currentUser && listing.owner && currentUser.clerkId === listing.owner.clerkId) { %>
                <div class="form-actions" style="margin-top:24px;" id="ownerActions">
                    <a href="/listings/<%= listing._id %>/edit" class="btn-secondary">Edit listing</a>
                    <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
                        <button type="submit" class="btn-danger">Delete listing</button>
                    </form>
                </div>
                <% } %>
            </aside>

            <!-- Styles for Booking interactive animation -->
            <style>
                @keyframes shake {
                    0%, 100% { transform: translateX(0); }
                    20%, 60% { transform: translateX(-6px); }
                    40%, 80% { transform: translateX(6px); }
                }
                .shake-element {
                    animation: shake 0.4s ease-in-out;
                    border-color: #b14646 !important;
                }
                .booking-spinner {
                    width: 54px;
                    height: 54px;
                    border: 4px solid var(--border-soft);
                    border-top: 4px solid var(--brand-moss);
                    border-radius: 50%;
                    animation: spin 1s linear infinite;
                    margin: 0 auto 24px;
                }
                @keyframes spin {
                    0% { transform: rotate(0deg); }
                    100% { transform: rotate(360deg); }
                }
                .step-item {
                    font-size: 0.95rem;
                    color: var(--text-soft);
                    margin: 12px 0;
                    display: flex;
                    align-items: center;
                    gap: 12px;
                    opacity: 0.35;
                    transition: opacity 0.4s, color 0.4s, font-weight 0.4s;
                }
                .step-item.active {
                    opacity: 1;
                    color: var(--brand-moss);
                    font-weight: 700;
                }
                .step-item.done {
                    opacity: 1;
                    color: var(--text-main);
                }
                .step-item.done i {
                    color: #4CAF50;
                }
                
                /* Success Checkmark Animation */
                .success-checkmark {
                    width: 80px;
                    height: 80px;
                    margin: 10px auto 20px;
                }
                .check-icon {
                    width: 80px;
                    height: 80px;
                    position: relative;
                    border-radius: 50%;
                    box-sizing: content-box;
                    border: 4px solid #4CAF50;
                }
                .check-icon-circle {
                    top: -4px;
                    left: -4px;
                    width: 80px;
                    height: 80px;
                    border-radius: 50%;
                    box-sizing: content-box;
                    border: 4px solid rgba(76, 175, 80, .1);
                    position: absolute;
                    z-index: 1;
                }
                .check-icon-fix {
                    top: 8px;
                    width: 5px;
                    left: 26px;
                    z-index: 1;
                    height: 85px;
                    position: absolute;
                    transform: rotate(-45deg);
                }
                .check-line {
                    height: 5px;
                    background-color: #4CAF50;
                    display: block;
                    border-radius: 2px;
                    position: absolute;
                    z-index: 10;
                }
                .check-line-tip {
                    width: 25px;
                    left: 14px;
                    top: 46px;
                    transform: rotate(45deg);
                    animation: icon-line-tip 0.6s ease-in-out;
                }
                .check-line-long {
                    width: 47px;
                    right: 8px;
                    top: 38px;
                    transform: rotate(-45deg);
                    animation: icon-line-long 0.6s ease-in-out;
                }
                @keyframes icon-line-tip {
                    0% { width: 0; left: 1px; top: 19px; }
                    54% { width: 0; left: 1px; top: 19px; }
                    100% { width: 25px; left: 14px; top: 46px; }
                }
                @keyframes icon-line-long {
                    0% { width: 0; right: 46px; top: 54px; }
                    54% { width: 0; right: 46px; top: 54px; }
                    100% { width: 47px; right: 8px; top: 38px; }
                }

                /* Confetti Animation */
                .confetti-container {
                    position: absolute;
                    top: 0;
                    left: 0;
                    width: 100%;
                    height: 100%;
                    overflow: hidden;
                    pointer-events: none;
                    z-index: 99;
                }
                .confetti-piece {
                    position: absolute;
                    width: 8px;
                    height: 14px;
                    background: #ffd300;
                    top: -20px;
                    opacity: 0;
                    animation: fall 2.5s infinite linear;
                }
                @keyframes fall {
                    0% { top: -20px; transform: rotate(0deg); opacity: 1; }
                    80% { opacity: 1; }
                    100% { top: 100%; transform: rotate(360deg); opacity: 0; }
                }
            </style>

            <script>
                document.addEventListener("DOMContentLoaded", () => {
                    const pricePerNight = Number("<%= listing.price || 0 %>");
                    const checkinInput = document.getElementById("checkin");
                    const checkoutInput = document.getElementById("checkout");
                    const guestsSelect = document.getElementById("guests");
                    const reserveBtn = document.getElementById("reserveBtn");
                    const bookingErrorAlert = document.getElementById("bookingErrorAlert");
                    const bookingErrorText = document.getElementById("bookingErrorText");
                    const bookingFormWrapper = document.getElementById("bookingFormWrapper");
                    const bookingLoadingWrapper = document.getElementById("bookingLoadingWrapper");
                    const bookingSuccessWrapper = document.getElementById("bookingSuccessWrapper");
                    const ownerActions = document.getElementById("ownerActions");
                    
                    // Fields for update
                    const nightsLabel = document.getElementById("nightsLabel");
                    const rawTotalDisplay = document.getElementById("rawTotalDisplay");
                    const serviceFeeDisplay = document.getElementById("serviceFeeDisplay");
                    const grandTotalDisplay = document.getElementById("grandTotalDisplay");
                    
                    // Success summary fields
                    const successBookingId = document.getElementById("successBookingId");
                    const successDates = document.getElementById("successDates");
                    const successNights = document.getElementById("successNights");
                    const successGuests = document.getElementById("successGuests");
                    const successTotal = document.getElementById("successTotal");
                    const resetBookingBtn = document.getElementById("resetBookingBtn");

                    const bookingFormCard = document.getElementById("bookingFormCard");

                    function updatePricing() {
                        const checkinVal = checkinInput.value;
                        const checkoutVal = checkoutInput.value;

                        if (checkinVal && checkoutVal) {
                            const date1 = new Date(checkinVal);
                            const date2 = new Date(checkoutVal);
                            const diffTime = date2 - date1;
                            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

                            if (diffDays <= 0) {
                                bookingErrorAlert.style.display = "flex";
                                bookingErrorText.textContent = "Check-out must be after check-in date.";
                                return false;
                            } else {
                                bookingErrorAlert.style.display = "none";
                                
                                const baseCost = pricePerNight * diffDays;
                                const serviceFee = Math.round(pricePerNight * 0.12);
                                const totalCost = baseCost + serviceFee;
                                
                                nightsLabel.innerHTML = `&#8377;${pricePerNight.toLocaleString("en-IN")} x ${diffDays} night${diffDays > 1 ? 's' : ''}`;
                                rawTotalDisplay.innerHTML = `&#8377;${baseCost.toLocaleString("en-IN")}`;
                                serviceFeeDisplay.innerHTML = `&#8377;${serviceFee.toLocaleString("en-IN")}`;
                                grandTotalDisplay.innerHTML = `&#8377;${totalCost.toLocaleString("en-IN")}`;
                                return diffDays;
                            }
                        }
                        
                        // Default fallback
                        bookingErrorAlert.style.display = "none";
                        const baseCost = pricePerNight * 2;
                        const serviceFee = Math.round(pricePerNight * 0.12);
                        const totalCost = baseCost + serviceFee;
                        nightsLabel.innerHTML = `&#8377;${pricePerNight.toLocaleString("en-IN")} x 2 nights`;
                        rawTotalDisplay.innerHTML = `&#8377;${baseCost.toLocaleString("en-IN")}`;
                        serviceFeeDisplay.innerHTML = `&#8377;${serviceFee.toLocaleString("en-IN")}`;
                        grandTotalDisplay.innerHTML = `&#8377;${totalCost.toLocaleString("en-IN")}`;
                        return false;
                    }

                    checkinInput.addEventListener("change", updatePricing);
                    checkoutInput.addEventListener("change", updatePricing);

                    // Confetti implementation
                    function generateConfetti() {
                        const container = document.getElementById("confettiContainer");
                        container.innerHTML = "";
                        const colors = ['#f5b799', '#2f6a56', '#ffd300', '#4CAF50', '#ff2a2a'];
                        for (let i = 0; i < 40; i++) {
                            const piece = document.createElement("div");
                            piece.className = "confetti-piece";
                            piece.style.left = Math.random() * 100 + "%";
                            piece.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
                            piece.style.animationDelay = Math.random() * 2 + "s";
                            piece.style.transform = `rotate(${Math.random() * 360}deg)`;
                            container.appendChild(piece);
                        }
                    }

                    // Reserve click handler
                    reserveBtn.addEventListener("click", () => {
                        const checkinVal = checkinInput.value;
                        const checkoutVal = checkoutInput.value;

                        if (!checkinVal || !checkoutVal) {
                            bookingErrorAlert.style.display = "flex";
                            bookingErrorText.textContent = "Please pick your check-in & check-out dates.";
                            bookingFormCard.classList.add("shake-element");
                            setTimeout(() => {
                                bookingFormCard.classList.remove("shake-element");
                            }, 500);
                            return;
                        }

                        const nights = updatePricing();
                        if (nights === false) {
                            bookingFormCard.classList.add("shake-element");
                            setTimeout(() => {
                                bookingFormCard.classList.remove("shake-element");
                            }, 500);
                            return;
                        }

                        // Start Loading Animation
                        bookingFormWrapper.style.display = "none";
                        if (ownerActions) ownerActions.style.display = "none";
                        bookingLoadingWrapper.style.display = "block";

                        const step1 = document.getElementById("step1");
                        const step2 = document.getElementById("step2");
                        const step3 = document.getElementById("step3");

                        // Step transitions
                        setTimeout(() => {
                            step1.classList.add("active");
                            step1.innerHTML = `<i class="fa-solid fa-circle-notch fa-spin"></i> Checking stay availability...`;
                        }, 200);

                        setTimeout(() => {
                            step1.classList.remove("active");
                            step1.classList.add("done");
                            step1.innerHTML = `<i class="fa-solid fa-circle-check"></i> Stay available!`;
                            
                            step2.classList.add("active");
                            step2.innerHTML = `<i class="fa-solid fa-circle-notch fa-spin"></i> Securing best price rate...`;
                        }, 1000);

                        setTimeout(() => {
                            step2.classList.remove("active");
                            step2.classList.add("done");
                            step2.innerHTML = `<i class="fa-solid fa-circle-check"></i> Rate locked: &#8377;${pricePerNight.toLocaleString("en-IN")}/night`;
                            
                            step3.classList.add("active");
                            step3.innerHTML = `<i class="fa-solid fa-circle-notch fa-spin"></i> Generating reservation token...`;
                        }, 2000);

                        setTimeout(() => {
                            step3.classList.remove("active");
                            step3.classList.add("done");
                            step3.innerHTML = `<i class="fa-solid fa-circle-check"></i> Token generated!`;
                        }, 2800);

                        // Success confirmation transition
                        setTimeout(() => {
                            bookingLoadingWrapper.style.display = "none";
                            bookingSuccessWrapper.style.display = "block";

                            // Generate Random Booking ID
                            const characters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
                            let bookingId = 'RM-';
                            for (let i = 0; i < 4; i++) {
                                bookingId += characters.charAt(Math.floor(Math.random() * characters.length));
                            }
                            bookingId += '-';
                            for (let i = 0; i < 4; i++) {
                                bookingId += characters.charAt(Math.floor(Math.random() * characters.length));
                            }
                            
                            // Format dates
                            const options = { month: 'short', day: 'numeric' };
                            const d1 = new Date(checkinVal).toLocaleDateString("en-US", options);
                            const d2 = new Date(checkoutVal).toLocaleDateString("en-US", options);
                            
                            const guestsCount = guestsSelect.value;
                            const totalVal = (pricePerNight * nights) + Math.round(pricePerNight * 0.12);

                            successBookingId.innerText = bookingId;
                            successDates.innerText = `${d1} - ${d2}`;
                            successNights.innerText = `${nights} night${nights > 1 ? 's' : ''}`;
                            successGuests.innerText = `${guestsCount} guest${guestsCount > 1 ? 's' : ''}`;
                            successTotal.innerHTML = `&#8377;${totalVal.toLocaleString("en-IN")}`;

                            // Play Confetti
                            generateConfetti();
                        }, 3300);
                    });

                    // Reset button handler
                    resetBookingBtn.addEventListener("click", () => {
                        bookingSuccessWrapper.style.display = "none";
                        bookingFormWrapper.style.display = "block";
                        if (ownerActions) ownerActions.style.display = "flex";
                        
                        // Clear fields
                        checkinInput.value = "";
                        checkoutInput.value = "";
                        checkinInput.type = "text";
                        checkoutInput.type = "text";
                        updatePricing();
                        
                        // Reset loading steps
                        const step1 = document.getElementById("step1");
                        const step2 = document.getElementById("step2");
                        const step3 = document.getElementById("step3");
                        
                        step1.className = "step-item";
                        step1.innerHTML = `<i class="fa-solid fa-hourglass-half"></i> Verifying dates...`;
                        
                        step2.className = "step-item";
                        step2.innerHTML = `<i class="fa-solid fa-lock"></i> Securing best price rate...`;
                        
                        step3.className = "step-item";
                        step3.innerHTML = `<i class="fa-solid fa-ticket"></i> Generating reservation token...`;
                    });
                });
            </script>
        </div>
    </div>
</section>
