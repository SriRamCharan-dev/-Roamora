<% layout('layouts/boilerplate') %>

<section class="page-section">
    <div class="container-shell form-shell">
        <div class="form-panel">
            <div class="form-hero">
                <div class="form-copy-card">
                    <div class="hero-badge"><i class="fa-solid fa-pen-to-square"></i> Listing refresh</div>
                    <h1>Update the details and keep the listing sharp.</h1>
                    <p class="muted-copy">This edit screen now matches the rest of the UI, with cleaner spacing, more premium presentation, and clearer calls to action.</p>
                </div>
                <div class="form-tip-card">
                    <h2 class="section-heading" style="font-size:1.45rem;">Quick improvements</h2>
                    <p class="muted-copy">Refresh the photo, tighten the wording, and keep the pricing realistic. Those three changes usually have the biggest visual impact.</p>
                </div>
            </div>

            <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" class="needs-validation" novalidate>
                <div class="form-grid">
                    <div class="field-group full-span">
                        <label for="title">Title <span class="required-mark">*</span></label>
                        <input type="text" id="title" name="title" value="<%= listing.title %>" required placeholder="Enter a catchy title" class="form-control">
                    </div>

                    <div class="field-group full-span">
                        <label for="description">Description <span class="required-mark">*</span></label>
                        <textarea id="description" name="description" required placeholder="Describe what makes this place special" class="form-control form-textarea" rows="6"><%= listing.description %></textarea>
                    </div>

                    <div class="field-group full-span">
                        <label for="image">Image URL</label>
                        <input type="url" id="image" name="image" value="<%= listing.image ? listing.image.url : '' %>" placeholder="Enter an image URL" class="form-control">
                    </div>

                    <div class="field-group">
                        <label for="price">Price per night <span class="required-mark">*</span></label>
                        <input type="number" id="price" name="price" value="<%= listing.price %>" required placeholder="Price in INR" class="form-control">
                    </div>

                    <div class="field-group">
                        <label for="location">Location <span class="required-mark">*</span></label>
                        <input type="text" id="location" name="location" value="<%= listing.location %>" required placeholder="e.g. Goa, Paris" class="form-control">
                    </div>

                    <div class="field-group full-span">
                        <label for="country">Country <span class="required-mark">*</span></label>
                        <input type="text" id="country" name="country" value="<%= listing.country %>" required placeholder="e.g. India, France" class="form-control">
                    </div>
                </div>

                <div class="form-actions">
                    <a href="/listings/<%= listing._id %>" class="btn-ghost">Back to listing</a>
                    <button class="btn-primary" type="submit">Save changes</button>
                </div>
            </form>
        </div>
    </div>
</section>
