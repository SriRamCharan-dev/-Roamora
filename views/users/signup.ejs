<% layout('layouts/boilerplate') %>

<style>
    .auth-card-wrapper {
        min-height: calc(100vh - 160px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
    }

    .auth-card {
        background: var(--surface-strong);
        border: 1px solid var(--border-soft);
        border-radius: var(--radius-xl, 24px);
        padding: 40px 36px;
        width: min(440px, 100%);
        box-shadow: 0 20px 50px rgba(24, 50, 42, 0.08);
    }

    .auth-card-header {
        text-align: center;
        margin-bottom: 28px;
    }

    .auth-card-logo {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--brand-moss);
        text-decoration: none;
        margin-bottom: 12px;
    }

    .auth-card-header h2 {
        font-size: 1.6rem;
        font-weight: 800;
        color: var(--brand-ink);
        margin: 0 0 6px;
        letter-spacing: -0.03em;
    }

    .auth-card-header p {
        color: var(--text-soft);
        font-size: 0.9rem;
        margin: 0;
    }

    .auth-form-group {
        margin-bottom: 18px;
    }

    .auth-form-group label {
        display: block;
        font-size: 0.85rem;
        font-weight: 700;
        color: var(--brand-ink);
        margin-bottom: 6px;
    }

    .auth-form-control {
        width: 100%;
        padding: 12px 16px;
        border-radius: 12px;
        border: 1px solid var(--border-soft);
        background: var(--surface-tint);
        font-size: 0.95rem;
        color: var(--brand-ink);
        font-family: inherit;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

    .auth-form-control:focus {
        outline: none;
        border-color: var(--brand-moss);
        box-shadow: 0 0 0 3px rgba(47, 106, 86, 0.15);
    }

    .auth-btn-primary {
        width: 100%;
        padding: 13px;
        border-radius: 12px;
        border: none;
        background: var(--brand-moss);
        color: #fff;
        font-weight: 700;
        font-size: 0.95rem;
        cursor: pointer;
        transition: background-color 0.2s ease, transform 0.1s ease;
        margin-top: 8px;
    }

    .auth-btn-primary:hover {
        background-color: #245242;
    }

    .auth-card-footer {
        text-align: center;
        margin-top: 24px;
        font-size: 0.88rem;
        color: var(--text-soft);
        border-top: 1px solid var(--border-soft);
        padding-top: 18px;
    }

    .auth-card-footer a {
        color: var(--brand-moss);
        font-weight: 700;
        text-decoration: none;
    }

    .auth-card-footer a:hover {
        text-decoration: underline;
    }
</style>

<div class="auth-card-wrapper">
    <div class="auth-card">
        <div class="auth-card-header">
            <a href="/" class="auth-card-logo">
                <i class="fa-brands fa-airbnb"></i>
                <span>Roamora</span>
            </a>
            <h2>Create Account</h2>
            <p>Sign up to start booking and hosting stays</p>
        </div>

        <form action="/signup" method="POST" class="needs-validation" novalidate>
            <div class="auth-form-group">
                <label for="username">Username</label>
                <input type="text" id="username" name="username" placeholder="Choose a username" class="auth-form-control" required minlength="3" autofocus>
                <div class="invalid-feedback">Username must be at least 3 characters.</div>
            </div>

            <div class="auth-form-group">
                <label for="email">Email address</label>
                <input type="email" id="email" name="email" placeholder="name@example.com" class="auth-form-control" required>
                <div class="invalid-feedback">Please enter a valid email.</div>
            </div>

            <div class="auth-form-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" placeholder="Create a password" class="auth-form-control" required minlength="4">
                <div class="invalid-feedback">Password must be at least 4 characters.</div>
            </div>

            <button class="auth-btn-primary" type="submit">Sign Up</button>
        </form>

        <div class="auth-card-footer">
            Already have an account? <a href="/login">Log in</a>
        </div>
    </div>
</div>