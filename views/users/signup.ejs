<% layout('layouts/boilerplate') %>

<style>
    .auth-card-wrapper {
        min-height: calc(100vh - 160px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 60px 20px;
        background: radial-gradient(circle at top center, rgba(47, 106, 86, 0.04) 0%, transparent 60%);
    }

    .auth-card {
        background: var(--surface-strong);
        border: 1px solid rgba(47, 106, 86, 0.1);
        border-radius: 28px;
        padding: 48px 44px;
        width: min(460px, 100%);
        box-shadow: 0 16px 48px -12px rgba(24, 50, 42, 0.15), 0 0 0 1px rgba(255,255,255,0.5) inset;
        position: relative;
        overflow: hidden;
        backdrop-filter: blur(10px);
    }

    .auth-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 5px;
        background: linear-gradient(90deg, var(--brand-moss) 0%, #63a98e 50%, var(--brand-moss) 100%);
    }

    .auth-card-header {
        text-align: center;
        margin-bottom: 36px;
    }

    .auth-card-logo {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        font-size: 1.7rem;
        font-weight: 800;
        color: var(--brand-moss);
        text-decoration: none;
        margin-bottom: 16px;
        letter-spacing: -0.02em;
    }

    .auth-card-logo i {
        font-size: 2.2rem;
        background: -webkit-linear-gradient(135deg, var(--brand-moss), #428d71);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .auth-card-header h2 {
        font-size: 1.85rem;
        font-weight: 800;
        color: var(--brand-ink);
        margin: 0 0 8px;
        letter-spacing: -0.03em;
    }

    .auth-card-header p {
        color: var(--text-soft);
        font-size: 0.95rem;
        margin: 0;
    }

    .auth-form-group {
        margin-bottom: 22px;
    }

    .auth-form-group label {
        display: block;
        font-size: 0.88rem;
        font-weight: 700;
        color: var(--brand-ink);
        margin-bottom: 8px;
    }

    .auth-form-control {
        width: 100%;
        padding: 14px 18px;
        border-radius: 14px;
        border: 1px solid var(--border-soft);
        background: var(--surface-tint);
        font-size: 1rem;
        color: var(--brand-ink);
        font-family: inherit;
        transition: all 0.3s ease;
    }

    .auth-form-control:focus {
        outline: none;
        border-color: var(--brand-moss);
        background: var(--surface-strong);
        box-shadow: 0 0 0 4px rgba(47, 106, 86, 0.12);
        transform: translateY(-1px);
    }

    .auth-btn-primary {
        width: 100%;
        padding: 15px;
        border-radius: 14px;
        border: none;
        background: linear-gradient(135deg, var(--brand-moss) 0%, #245242 100%);
        color: #fff;
        font-weight: 700;
        font-size: 1.05rem;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-top: 12px;
        box-shadow: 0 4px 14px rgba(36, 82, 66, 0.25);
    }

    .auth-btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(36, 82, 66, 0.35);
    }

    .auth-card-footer {
        text-align: center;
        margin-top: 32px;
        font-size: 0.92rem;
        color: var(--text-soft);
        border-top: 1px solid var(--border-soft);
        padding-top: 24px;
    }

    .auth-card-footer a {
        color: var(--brand-moss);
        font-weight: 700;
        text-decoration: none;
        transition: color 0.2s ease;
    }

    .auth-card-footer a:hover {
        text-decoration: underline;
        color: #1c4234;
    }
</style>

<div class="auth-card-wrapper">
    <div class="auth-card">
        <div class="auth-card-header">
            <a href="/" class="auth-card-logo">
                <i class="fa-brands fa-airbnb"></i>
                <span>Roamora</span>
            </a>
            <h2>Create Account</h2>
            <p>Sign up to start booking and hosting stays</p>
        </div>

        <form action="/signup" method="POST" class="needs-validation" novalidate>
            <div class="auth-form-group">
                <label for="username">Username</label>
                <input type="text" id="username" name="username" placeholder="Choose a username" class="auth-form-control" required minlength="3" autofocus>
                <div class="invalid-feedback">Username must be at least 3 characters.</div>
            </div>

            <div class="auth-form-group">
                <label for="email">Email address</label>
                <input type="email" id="email" name="email" placeholder="name@example.com" class="auth-form-control" required>
                <div class="invalid-feedback">Please enter a valid email.</div>
            </div>

            <div class="auth-form-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" placeholder="Create a password" class="auth-form-control" required minlength="4">
                <div class="invalid-feedback">Password must be at least 4 characters.</div>
            </div>

            <button class="auth-btn-primary" type="submit">Sign Up</button>
        </form>

        <div class="auth-card-footer">
            Already have an account? <a href="/login">Log in</a>
        </div>
    </div>
</div>