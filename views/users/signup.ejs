<% layout('layouts/boilerplate') %>

<section class="page-section">
    <div class="container-shell form-shell">
        <div class="form-panel">
            <div class="form-hero">
                <div class="form-copy-card">
                    <div class="hero-badge"><i class="fa-solid fa-user-plus"></i> Join Roamora</div>
                    <h1>Create your account</h1>
                    <p class="muted-copy">Discover and share beautiful stays. Set up your login details to get started with planning your next journey.</p>
                </div>
                <div class="form-tip-card">
                    <h2 class="section-heading" style="font-size:1.45rem;">Why register?</h2>
                    <p class="muted-copy">Get full access to add and manage listings, share experiences with review comments, and keep track of your favorite stays across beaches, mountains, and cities.</p>
                </div>
            </div>

            <form action="/signup" method="POST" class="needs-validation" novalidate>
                <div class="form-grid">
                    <div class="field-group full-span">
                        <label for="username">Username <span class="required-mark">*</span></label>
                        <input type="text" id="username" name="username" placeholder="Choose a username" class="form-control" required minlength="3">
                        <div class="invalid-feedback">Please choose a username (minimum 3 characters).</div>
                        <div class="valid-feedback">Looks good!</div>
                    </div>

                    <div class="field-group full-span">
                        <label for="email">Email <span class="required-mark">*</span></label>
                        <input type="email" id="email" name="email" placeholder="Enter your email" class="form-control" required>
                        <div class="invalid-feedback">Please enter a valid email address.</div>
                        <div class="valid-feedback">Looks good!</div>
                    </div>

                    <div class="field-group full-span">
                        <label for="password">Password <span class="required-mark">*</span></label>
                        <input type="password" id="password" name="password" placeholder="Create a password" class="form-control" required minlength="4">
                        <div class="invalid-feedback">Please enter a password (minimum 4 characters).</div>
                        <div class="valid-feedback">Looks good!</div>
                    </div>
                </div>

                <div class="form-actions" style="flex-direction: column; align-items: stretch; gap: 16px;">
                    <button class="btn-primary" type="submit" style="width: 100%;">Create Account</button>
                    <div style="text-align: center; font-size: 0.95rem; margin-top: 12px;">
                        Already have an account? <a href="/login" style="font-weight: 700; color: var(--brand-moss); text-decoration: underline;">Log in here</a>
                    </div>
                </div>

            </form>
        </div>
    </div>
</section>