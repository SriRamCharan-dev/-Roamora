<% layout('layouts/boilerplate') %>

<section class="page-section">
    <div class="container-shell form-shell">
        <div class="form-panel">
            <div class="form-hero">
                <div class="form-copy-card">
                    <div class="hero-badge"><i class="fa-solid fa-right-to-bracket"></i> Welcome Back</div>
                    <h1>Log in to Roamora</h1>
                    <p class="muted-copy">Access your account to book stays, host properties, or review your recent travel experiences.</p>
                </div>
                <div class="form-tip-card">
                    <h2 class="section-heading" style="font-size:1.45rem;">Looking for stays?</h2>
                    <p class="muted-copy">Explore standout homes, warm escapes, and design-forward properties. Simply log in or sign up to interact with listing authors and reviews.</p>
                </div>
            </div>

            <form action="/login" method="POST" class="needs-validation" novalidate>
                <div class="form-grid">
                    <div class="field-group full-span">
                        <label for="username">Username <span class="required-mark">*</span></label>
                        <input type="text" id="username" name="username" placeholder="Enter your username" class="form-control" required>
                        <div class="invalid-feedback">Please enter your username.</div>
                        <div class="valid-feedback">Looks good!</div>
                    </div>

                    <div class="field-group full-span">
                        <label for="password">Password <span class="required-mark">*</span></label>
                        <input type="password" id="password" name="password" placeholder="Enter your password" class="form-control" required>
                        <div class="invalid-feedback">Please enter your password.</div>
                        <div class="valid-feedback">Looks good!</div>
                    </div>
                </div>

                <div class="form-actions" style="flex-direction: column; align-items: stretch; gap: 16px;">
                    <button class="btn-primary" type="submit" style="width: 100%;">Log In</button>
                    <div style="text-align: center; color: var(--text-soft); font-size: 0.9rem; margin: 8px 0;">— OR —</div>
                    <a href="/auth/google" class="btn-google" style="width: 100%;">
                        <i class="fa-brands fa-google"></i> Continue with Google
                    </a>
                    <div style="text-align: center; font-size: 0.95rem; margin-top: 12px;">
                        New to Roamora? <a href="/signup" style="font-weight: 700; color: var(--brand-moss); text-decoration: underline;">Create an account</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</section>