<%- layout('layouts/boilerplate') %>

<style>
  /* ── Hero page: full-bleed, no container padding ─────────────────── */
  main.container { padding: 0 !important; max-width: 100% !important; overflow-x: hidden; }

  /* ── Hero Section ────────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: calc(100vh - 70px);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 80px 24px 60px;
  }

  /* Ambient blobs */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 10% 20%, rgba(245,183,153,0.45) 0%, transparent 60%),
      radial-gradient(ellipse 55% 45% at 90% 70%, rgba(47,106,86,0.18) 0%, transparent 55%),
      radial-gradient(ellipse 40% 40% at 50% -10%, rgba(47,106,86,0.12) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
  }

  /* Floating decorative rings */
  .hero-ring {
    position: absolute;
    border-radius: 50%;
    border: 1.5px solid rgba(47,106,86,0.14);
    animation: float-ring 12s ease-in-out infinite;
    pointer-events: none;
    z-index: 0;
  }
  .hero-ring-1 { width: 500px; height: 500px; top: -120px; left: -180px; animation-delay: 0s; }
  .hero-ring-2 { width: 360px; height: 360px; bottom: -80px; right: -100px; animation-delay: 3s; border-color: rgba(245,183,153,0.2); }
  .hero-ring-3 { width: 200px; height: 200px; top: 30%; right: 8%; animation-delay: 6s; border-color: rgba(47,106,86,0.1); }

  @keyframes float-ring {
    0%,100% { transform: translate(0,0) scale(1); }
    50%      { transform: translate(12px,-18px) scale(1.03); }
  }

  /* ── Content wrapper ─────────────────────────────────────────────── */
  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
  }

  /* ── Left copy ───────────────────────────────────────────────────── */
  .hero-copy { display: flex; flex-direction: column; gap: 28px; }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(47,106,86,0.1);
    border: 1px solid rgba(47,106,86,0.2);
    color: var(--brand-moss);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 100px;
    width: fit-content;
    backdrop-filter: blur(6px);
  }
  .hero-badge .badge-dot {
    width: 6px; height: 6px;
    background: var(--brand-moss);
    border-radius: 50%;
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%,100% { transform: scale(1); opacity: 1; }
    50%      { transform: scale(1.4); opacity: 0.6; }
  }

  .hero-title {
    font-size: clamp(2.8rem, 5.5vw, 4.2rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--brand-ink);
    margin: 0;
  }
  .hero-title .accent {
    background: linear-gradient(135deg, var(--brand-moss) 0%, #4fa882 50%, var(--brand-peach) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: 1.1rem;
    line-height: 1.75;
    color: var(--text-soft);
    max-width: 480px;
    margin: 0;
  }

  /* ── CTA Buttons ─────────────────────────────────────────────────── */
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }
  .btn-hero-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: linear-gradient(135deg, var(--brand-moss) 0%, #3d8c72 100%);
    color: #fff;
    font-size: 0.97rem;
    font-weight: 700;
    padding: 16px 34px;
    border-radius: 100px;
    text-decoration: none;
    box-shadow: 0 8px 32px rgba(47,106,86,0.35), 0 2px 8px rgba(47,106,86,0.2);
    transition: transform 0.22s ease, box-shadow 0.22s ease, filter 0.22s ease;
    letter-spacing: 0.01em;
  }
  .btn-hero-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 48px rgba(47,106,86,0.42), 0 4px 16px rgba(47,106,86,0.28);
    filter: brightness(1.06);
    color: #fff;
    text-decoration: none;
  }
  .btn-hero-secondary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: rgba(255,255,255,0.7);
    backdrop-filter: blur(12px);
    border: 1.5px solid var(--border-soft);
    color: var(--brand-ink);
    font-size: 0.97rem;
    font-weight: 700;
    padding: 15px 30px;
    border-radius: 100px;
    text-decoration: none;
    transition: transform 0.22s ease, box-shadow 0.22s ease, background 0.22s ease;
    letter-spacing: 0.01em;
  }
  .btn-hero-secondary:hover {
    transform: translateY(-3px);
    background: rgba(255,255,255,0.9);
    box-shadow: 0 8px 24px rgba(24,50,42,0.1);
    color: var(--brand-ink);
    text-decoration: none;
  }

  /* ── Social proof strip ──────────────────────────────────────────── */
  .hero-proof {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }
  .proof-avatars {
    display: flex;
    align-items: center;
  }
  .proof-avatars .av {
    width: 36px; height: 36px;
    border-radius: 50%;
    border: 2.5px solid #fffdf8;
    background: linear-gradient(135deg, var(--brand-moss), var(--brand-peach));
    display: flex; align-items: center; justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    color: #fff;
    margin-left: -10px;
    flex-shrink: 0;
  }
  .proof-avatars .av:first-child { margin-left: 0; }
  .proof-text { font-size: 0.84rem; line-height: 1.4; color: var(--text-soft); }
  .proof-text strong { color: var(--brand-ink); font-weight: 700; }

  .proof-divider {
    width: 1px; height: 32px;
    background: var(--border-soft);
    flex-shrink: 0;
  }
  .proof-stat { text-align: center; }
  .proof-stat .num { font-size: 1.25rem; font-weight: 800; color: var(--brand-ink); display: block; }
  .proof-stat .lbl { font-size: 0.76rem; color: var(--text-soft); font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; }

  /* ── Right visual card stack ─────────────────────────────────────── */
  .hero-visual {
    position: relative;
    height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-card {
    position: absolute;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    transition: transform 0.6s ease;
  }
  /* Main large card */
  .hero-card-main {
    width: 320px;
    height: 420px;
    background: linear-gradient(160deg, #2f6a56 0%, #1e4d3c 40%, #3d8c72 100%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 28px;
    z-index: 3;
    transform: rotate(-2deg);
    animation: card-float 8s ease-in-out infinite;
  }
  .hero-card-main:hover { transform: rotate(0deg) scale(1.02); }

  @keyframes card-float {
    0%,100% { transform: rotate(-2deg) translateY(0); }
    50%      { transform: rotate(-2deg) translateY(-14px); }
  }

  /* Decorative overlays on main card */
  .hero-card-main::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 30% 20%, rgba(245,183,153,0.3) 0%, transparent 50%),
      radial-gradient(circle at 80% 80%, rgba(255,255,255,0.06) 0%, transparent 40%);
    pointer-events: none;
  }

  .card-icon-wrap {
    position: absolute;
    top: 24px; right: 24px;
    width: 56px; height: 56px;
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(8px);
    border-radius: var(--radius-md);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.5rem;
  }

  .card-location {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.65);
    margin-bottom: 6px;
  }
  .card-title {
    font-size: 1.3rem;
    font-weight: 800;
    color: #fff;
    margin-bottom: 14px;
    line-height: 1.25;
  }
  .card-price-row {
    display: flex;
    align-items: baseline;
    gap: 4px;
  }
  .card-price { font-size: 1.5rem; font-weight: 800; color: #fff; }
  .card-per   { font-size: 0.82rem; color: rgba(255,255,255,0.6); }

  .card-rating {
    position: absolute;
    top: 24px; left: 24px;
    background: rgba(255,255,255,0.18);
    backdrop-filter: blur(10px);
    border-radius: 100px;
    padding: 5px 12px;
    font-size: 0.82rem;
    font-weight: 700;
    color: #fff;
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .card-rating .star { color: #fbbf24; }

  /* Secondary floating cards */
  .hero-card-sm {
    width: 200px;
    background: var(--surface-strong);
    border: 1px solid var(--border-soft);
    padding: 18px 20px;
    z-index: 4;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .hero-card-sm-1 {
    top: 30px; right: -20px;
    transform: rotate(3deg);
    animation: card-float-sm1 9s ease-in-out infinite;
  }
  .hero-card-sm-2 {
    bottom: 40px; left: -20px;
    transform: rotate(-3deg);
    animation: card-float-sm2 10s ease-in-out infinite;
  }
  @keyframes card-float-sm1 {
    0%,100% { transform: rotate(3deg) translateY(0); }
    50%      { transform: rotate(3deg) translateY(-10px); }
  }
  @keyframes card-float-sm2 {
    0%,100% { transform: rotate(-3deg) translateY(0); }
    50%      { transform: rotate(-3deg) translateY(10px); }
  }

  .sm-card-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-soft);
  }
  .sm-card-value {
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--brand-ink);
  }
  .sm-card-sub {
    font-size: 0.78rem;
    color: var(--text-soft);
  }
  .sm-card-icon {
    width: 40px; height: 40px;
    border-radius: var(--radius-sm);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.1rem;
    flex-shrink: 0;
  }
  .sm-card-row { display: flex; align-items: center; gap: 12px; }
  .badge-green {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.72rem;
    font-weight: 700;
    color: #1e8a60;
    background: rgba(30,138,96,0.12);
    border-radius: 100px;
    padding: 3px 9px;
  }

  /* ── Features strip ──────────────────────────────────────────────── */
  .hero-features {
    position: relative; z-index: 1;
    max-width: 1200px;
    margin: 60px auto 80px;
    padding: 0 24px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .feature-card {
    background: rgba(255,255,255,0.6);
    backdrop-filter: blur(16px);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-lg);
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .feature-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 50px rgba(24,50,42,0.1);
  }
  .feature-icon {
    width: 52px; height: 52px;
    border-radius: var(--radius-md);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem;
    flex-shrink: 0;
  }
  .feature-icon.green  { background: rgba(47,106,86,0.12); color: var(--brand-moss); }
  .feature-icon.peach  { background: rgba(245,183,153,0.25); color: #c4724a; }
  .feature-icon.blue   { background: rgba(79,168,130,0.12); color: #2d7a6e; }

  .feature-title { font-size: 1.08rem; font-weight: 700; color: var(--brand-ink); }
  .feature-desc  { font-size: 0.88rem; line-height: 1.65; color: var(--text-soft); }

  /* ── Dark mode overrides ─────────────────────────────────────────── */
  body.dark-mode .btn-hero-secondary {
    background: rgba(22,31,27,0.7);
    border-color: rgba(237,245,239,0.18);
    color: var(--brand-ink);
  }
  body.dark-mode .btn-hero-secondary:hover {
    background: rgba(30,42,36,0.9);
    color: var(--brand-ink);
  }
  body.dark-mode .hero-card-sm {
    background: rgba(22,31,27,0.9);
    border-color: rgba(237,245,239,0.12);
  }
  body.dark-mode .sm-card-value,
  body.dark-mode .feature-title { color: var(--brand-ink); }
  body.dark-mode .feature-card {
    background: rgba(22,31,27,0.6);
    border-color: rgba(237,245,239,0.1);
  }
  body.dark-mode .proof-avatars .av { border-color: #101714; }

  /* ── Responsive ──────────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; gap: 48px; text-align: center; }
    .hero-sub   { margin: 0 auto; }
    .hero-badge { margin: 0 auto; }
    .hero-actions { justify-content: center; }
    .hero-proof   { justify-content: center; }
    .hero-visual  { height: 380px; }
    .hero-card-main { width: 260px; height: 340px; }
    .hero-card-sm  { display: none; }
    .hero-features { grid-template-columns: 1fr; }
  }
</style>

<!-- ─── Hero ─────────────────────────────────────────────────────────── -->
<section class="hero">
  <div class="hero-ring hero-ring-1"></div>
  <div class="hero-ring hero-ring-2"></div>
  <div class="hero-ring hero-ring-3"></div>

  <div class="hero-inner">
    <!-- Left copy -->
    <div class="hero-copy">
      <span class="hero-badge">
        <span class="badge-dot"></span>
        New listings every day
      </span>

      <h1 class="hero-title">
        Find your next<br>
        <span class="accent">unforgettable</span><br>
        escape
      </h1>

      <p class="hero-sub">
        Discover handpicked stays around the world — from cosy mountain cabins to 
        oceanfront villas. Book instantly, live authentically.
      </p>

      <div class="hero-actions">
        <a href="/listings" class="btn-hero-primary">
          <i class="fa-solid fa-magnifying-glass"></i>
          Explore stays
        </a>
        <a href="/listings/new" class="btn-hero-secondary">
          <i class="fa-solid fa-plus"></i>
          Host a place
        </a>
      </div>

      <!-- Social proof -->
      <div class="hero-proof">
        <div class="proof-avatars">
          <div class="av" style="background:linear-gradient(135deg,#2f6a56,#4fa882)">A</div>
          <div class="av" style="background:linear-gradient(135deg,#c4724a,#f5b799)">M</div>
          <div class="av" style="background:linear-gradient(135deg,#3d8c72,#2f6a56)">R</div>
          <div class="av" style="background:linear-gradient(135deg,#f5b799,#c4724a)">S</div>
        </div>
        <div class="proof-text">
          <strong>2,400+</strong> travellers<br>booked this week
        </div>
        <div class="proof-divider"></div>
        <div class="proof-stat">
          <span class="num">⭐ 4.9</span>
          <span class="lbl">Avg. rating</span>
        </div>
        <div class="proof-divider"></div>
        <div class="proof-stat">
          <span class="num">180+</span>
          <span class="lbl">Countries</span>
        </div>
      </div>
    </div>

    <!-- Right visual -->
    <div class="hero-visual">
      <!-- Main card -->
      <div class="hero-card hero-card-main">
        <div class="card-icon-wrap">🏡</div>
        <div class="card-rating">
          <span class="star">★</span> 4.97
        </div>
        <div class="card-location">Tuscany, Italy</div>
        <div class="card-title">Rustic Villa with<br>Vineyard Views</div>
        <div class="card-price-row">
          <span class="card-price">$220</span>
          <span class="card-per">/ night</span>
        </div>
      </div>

      <!-- Floating mini card 1 — availability -->
      <div class="hero-card hero-card-sm hero-card-sm-1">
        <div class="sm-card-row">
          <div class="sm-card-icon" style="background:rgba(30,138,96,0.12);color:#1e8a60;">
            <i class="fa-solid fa-calendar-check"></i>
          </div>
          <div>
            <div class="sm-card-label">Available</div>
            <div class="sm-card-value" style="font-size:1.1rem;">Aug 12–19</div>
          </div>
        </div>
        <div class="badge-green">
          <i class="fa-solid fa-circle" style="font-size:0.45rem;"></i>
          Instant book
        </div>
      </div>

      <!-- Floating mini card 2 — savings -->
      <div class="hero-card hero-card-sm hero-card-sm-2">
        <div class="sm-card-label">Total savings</div>
        <div class="sm-card-value">$340</div>
        <div class="sm-card-sub">vs. similar hotels nearby</div>
      </div>
    </div>
  </div>
</section>

<!-- ─── Features strip ────────────────────────────────────────────────── -->
<div class="hero-features">
  <div class="feature-card">
    <div class="feature-icon green">
      <i class="fa-solid fa-shield-halved"></i>
    </div>
    <div class="feature-title">Verified listings</div>
    <div class="feature-desc">Every property is manually reviewed before it goes live — so you can book with total confidence.</div>
  </div>

  <div class="feature-card">
    <div class="feature-icon peach">
      <i class="fa-solid fa-bolt"></i>
    </div>
    <div class="feature-title">Instant booking</div>
    <div class="feature-desc">Skip the wait. Confirm your stay in seconds and get your check-in details right away.</div>
  </div>

  <div class="feature-card">
    <div class="feature-icon blue">
      <i class="fa-solid fa-headset"></i>
    </div>
    <div class="feature-title">24 / 7 support</div>
    <div class="feature-desc">Our team is always on — whether you need last-minute help or a simple question answered.</div>
  </div>
</div>
